[
  {
    "id": "redeploy-rom-finder",
    "execute-command": "/scripts/redeploy.sh",
    "command-working-directory": "/scripts",
    "response-message": "Redeploying rom-finder — this takes ~30 seconds.",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv \"WEBHOOK_TOKEN\" }}",
        "parameter": {
          "source": "header",
          "name": "X-Deploy-Token"
        }
      }
    }
  }
]
